{%- comment -%}
  Outputs inline CSS custom properties for responsive heading sizes.
  Usage: {% render 'heading-size-vars', desktop: section.settings.heading_size, mobile: section.settings.heading_sizeheading_mobileobile, scale: 'default' %}
  Scales: 'default' (section headings), 'hero' (hero/banner large headings)
  Put inside a style="" attribute on the heading element.
{%- endcomment -%}

{%- if scale == 'hero' -%}
  {%- case desktop -%}
    {%- when 'small' -%}{%- assign heading_desktop = '2rem' -%}
    {%- when 'large' -%}{%- assign heading_desktop = '3.5rem' -%}
    {%- when 'extra_large' -%}{%- assign heading_desktop = '4.5rem' -%}
    {%- else -%}{%- assign heading_desktop = '2.75rem' -%}
  {%- endcase -%}
  {%- case mobile -%}
    {%- when 'small' -%}{%- assign heading_mobile = '1.5rem' -%}
    {%- when 'large' -%}{%- assign heading_mobile = '2.5rem' -%}
    {%- when 'extra_large' -%}{%- assign heading_mobile = '3rem' -%}
    {%- else -%}{%- assign heading_mobile = '2rem' -%}
  {%- endcase -%}
{%- else -%}
  {%- case desktop -%}
    {%- when 'small' -%}{%- assign heading_desktop = '1.5rem' -%}
    {%- when 'large' -%}{%- assign heading_desktop = '2.75rem' -%}
    {%- when 'extra_large' -%}{%- assign heading_desktop = '3.5rem' -%}
    {%- else -%}{%- assign heading_desktop = '2rem' -%}
  {%- endcase -%}
  {%- case mobile -%}
    {%- when 'small' -%}{%- assign heading_mobile = '1.25rem' -%}
    {%- when 'large' -%}{%- assign heading_mobile = '2rem' -%}
    {%- when 'extra_large' -%}{%- assign heading_mobile = '2.5rem' -%}
    {%- else -%}{%- assign heading_mobile = '1.5rem' -%}
  {%- endcase -%}
{%- endif -%}
--heading-size: {{ heading_desktop }}; --heading-size-mobile: {{ heading_mobile }};
